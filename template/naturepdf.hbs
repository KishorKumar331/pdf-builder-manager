<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Journey Routers - Botanical Journal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Dancing+Script:wght@400..700&family=Montserrat:wght@300;400;700&family=Lora:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: "Lora", serif;
            background: #fdfaf5;
            color: #2b3a30;
            -webkit-print-color-adjust: exact;
        }

        .pdf-page {
            width: 210mm;
            height: 297mm;
            position: relative;
            overflow: hidden;
            page-break-after: always;
            background: #fdfaf5;
        }

        .pdf-page:last-child {
            page-break-after: auto;
        }

        /* Decorative Elements */
        .botanical-circle {
            position: absolute;
            border-radius: 50%;
            background: rgba(43, 58, 48, 0.03);
            z-index: -1;
        }

        .floating-badge {
            background: #d4a373;
            color: white;
            padding: 10px 20px;
            border-radius: 50px;
            font-family: 'Montserrat', sans-serif;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* Typography */
        .title-display { font-family: 'DM Serif Display', serif; font-size: 72px; line-height: 0.9; color: #2b3a30; }
        .sub-hand { font-family: 'Dancing Script', cursive; font-size: 28px; color: #d4a373; }
        .label-modern { font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; opacity: 0.6; }

        /* Cover Design */
        .cover-visual {
            position: absolute;
            top: -50px;
            right: -50px;
            width: 450px;
            height: 450px;
            border-radius: 50%;
            background: #e9edc9;
            overflow: hidden;
            border: 15px solid white;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        .cover-visual img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .cover-content {
            padding: 100mm 20mm 20mm;
        }

        /* Overview Grid */
        .staggered-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            padding: 0 20mm;
        }

        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 40px 10px 40px 10px;
            border: 1px solid #f1f3f0;
            box-shadow: 0 10px 25px rgba(43, 58, 48, 0.03);
        }

        /* Pricing Medallion */
        .pricing-medallion {
            width: 180px;
            height: 180px;
            background: #2b3a30;
            color: #fefae0;
            border-radius: 50%;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            margin: 40px auto;
            border: 2px solid #d4a373;
            box-shadow: 0 15px 35px rgba(43, 58, 48, 0.2);
        }

        /* Timeline */
        .botanical-timeline {
            margin: 40px 20mm;
            position: relative;
        }

        .timeline-leaf {
            display: flex;
            align-items: center;
            gap: 30px;
            margin-bottom: 30px;
        }

        .day-circle {
            width: 50px;
            height: 50px;
            border-radius: 50% 0 50% 0;
            background: #ccd5ae;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'DM Serif Display';
            font-size: 20px;
            color: #2b3a30;
        }

        /* Detailed Pages */
        .image-leaf-mask {
            width: 100%;
            height: 350px;
            border-radius: 150px 0 150px 0;
            overflow: hidden;
            margin-bottom: 40px;
            border: 10px solid white;
            box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        }

        /* Footer */
        .botanical-footer {
            position: absolute;
            bottom: 40px;
            left: 20mm;
            right: 20mm;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-family: 'Montserrat';
            font-size: 9px;
            letter-spacing: 2px;
            color: #a3ad98;
        }

    </style>
</head>

<body>
    <!-- ================= PAGE 1 : COVER ================= -->
    <div class="pdf-page">
        <div class="botanical-circle" style="width: 600px; height: 600px; top: -100px; left: -100px;"></div>
        
        <div class="cover-visual">
            <img src="{{assetsBaseUrl}}/header.png" alt="Destination Image">
        </div>

        <div class="cover-content">
            <div class="sub-hand">The Great Escape to</div>
            <h1 class="title-display">{{trip.destination}}</h1>
            <div style="width: 80px; height: 2px; background: #d4a373; margin: 30px 0;"></div>
            
            <div style="margin-top: 50px;">
                <div class="label-modern" style="margin-bottom: 10px;">Created For</div>
                <div class="title-display" style="font-size: 36px;">{{customer.name}}</div>
            </div>

            <div style="margin-top: 40px; display: flex; gap: 40px;">
                <div>
                    <div class="label-modern">Duration</div>
                    <div style="font-size: 18px; font-weight: 600;">{{trip.days}} Successful Days</div>
                </div>
                <div>
                    <div class="label-modern">Organized By</div>
                    <div style="font-size: 18px; font-weight: 600;">{{user.CompanyName}}</div>
                </div>
            </div>
        </div>

        <div class="botanical-footer">
            <div>EXPLORE@JOURNEYROUTERS.COM</div>
            <div>EST. 2024</div>
        </div>
    </div>

    <!-- ================= PAGE 2 : OVERVIEW ================= -->
    <div class="pdf-page">
        <div class="botanical-circle" style="width: 400px; height: 400px; bottom: -100px; right: -100px; background: rgba(212, 163, 115, 0.05);"></div>
        
        <div style="padding: 40mm 20mm 20mm; text-align: center;">
            <div class="sub-hand" style="font-size: 32px; margin-bottom: 10px;">Adventure Awaits</div>
            <h2 class="title-display" style="font-size: 48px; border-bottom: 1px solid rgba(212, 163, 115, 0.2); display: inline-block; padding-bottom: 15px;">Journey Summary</h2>
        </div>

        <div class="staggered-grid">
            <div class="feature-card" style="margin-top: 20px;">
                <div class="label-modern" style="color: #ccd5ae;">Destination</div>
                <div style="font-size: 22px; font-weight: 700; margin-top: 8px;">{{trip.destination}}</div>
                <p style="font-size: 12px; margin-top: 10px; opacity: 0.6;">A curated expedition through the heart of {{trip.destination}}.</p>
            </div>
            <div class="feature-card" style="margin-top: -10px;">
                <div class="label-modern" style="color: #d4a373;">Total Group</div>
                <div style="font-size: 22px; font-weight: 700; margin-top: 8px;">{{trip.pax}} Travellers</div>
                <p style="font-size: 12px; margin-top: 10px; opacity: 0.6;">Inclusive of all premium land services.</p>
            </div>
            <div class="feature-card" style="margin-top: 20px;">
                <div class="label-modern" style="color: #2b3a30;">Accommodation</div>
                <div style="font-size: 22px; font-weight: 700; margin-top: 8px;">{{#if trip.hotelCategory}}{{trip.hotelCategory}} Star{{else}}Boutique{{/if}} Comfort</div>
                <p style="font-size: 12px; margin-top: 10px; opacity: 0.6;">Handpicked stays for a restful journey.</p>
            </div>
            <div class="feature-card" style="margin-top: -10px;">
                <div class="label-modern" style="color: #ccd5ae;">Meal Plan</div>
                <div style="font-size: 22px; font-weight: 700; margin-top: 8px;">{{#if trip.mealPlan}}{{trip.mealPlan}}{{else}}B'fast & Dinner{{/if}}</div>
                <p style="font-size: 12px; margin-top: 10px; opacity: 0.6;">Local flavors and culinary highlights.</p>
            </div>
        </div>

        <div class="pricing-medallion">
            <div class="label-modern" style="color: #fefae0; opacity: 0.8;">Total Trip Cost</div>
            <div class="title-display" style="font-size: 42px; color: #fefae0; margin: 5px 0;">₹{{pricing.totalCost}}</div>
            <div style="font-size: 10px; text-transform: uppercase; font-weight: 700; letter-spacing: 1px; color: #d4a373;">Per Person</div>
        </div>
    </div>

    <!-- ================= PAGE 3 : INCLUSIONS ================= -->
    <div class="pdf-page">
        <div style="padding: 40mm 20mm 20mm;">
             <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px;">
                <div>
                    <h3 class="title-display" style="font-size: 36px; margin-bottom: 30px;">What's<br>Inside</h3>
                    <div style="width: 40px; height: 4px; background: #ccd5ae; margin-bottom: 30px;"></div>
                    {{#each inclusions}}
                    <div style="display: flex; gap: 15px; align-items: center; margin-bottom: 12px;">
                        <div style="width: 8px; height: 8px; background: #d4a373; border-radius: 50%;"></div>
                        <div style="font-size: 13px; font-weight: 600;">{{this}}</div>
                    </div>
                    {{/each}}
                </div>
                <div style="background: rgba(43, 58, 48, 0.02); padding: 40px; border-radius: 50px 50px 0 50px;">
                    <h3 class="title-display" style="font-size: 36px; margin-bottom: 30px; color: #a3ad98;">Not<br>Included</h3>
                    {{#each exclusions}}
                    <div style="display: flex; gap: 15px; align-items: center; margin-bottom: 12px; opacity: 0.5;">
                        <div style="width: 8px; height: 1px; background: #2b3a30;"></div>
                        <div style="font-size: 13px;">{{this}}</div>
                    </div>
                    {{/each}}
                </div>
             </div>
        </div>
    </div>

    <!-- ================= PAGE 4 : ITINERARY ================= -->
    <div class="pdf-page">
        <div style="padding: 40mm 20mm 20mm;">
            <h2 class="title-display" style="font-size: 48px; margin-bottom: 50px;">The Timeline</h2>
            
            <div class="botanical-timeline">
                {{#each itinerary}}
                <div class="timeline-leaf">
                    <div class="day-circle">{{Day}}</div>
                    <div>
                        <div class="label-modern" style="color: #d4a373;">Day Journey</div>
                        <div style="font-size: 18px; font-weight: 700; color: #2b3a30;">{{Title}}</div>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </div>

    <!-- ================= DETAIL ITINERARY ================= -->
    {{#each itinerary}}
    <div class="pdf-page">
        <div style="padding: 40mm 20mm 20mm;">
            {{#if ImageUrl}}
            <div class="image-leaf-mask">
                <img src="{{ImageUrl}}" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            {{/if}}
            
            <div style="display: flex; align-items: baseline; gap: 20px; margin-bottom: 30px;">
                <div class="title-display" style="font-size: 64px; color: #ccd5ae;">0{{Day}}</div>
                <h3 class="title-display" style="font-size: 36px; border-left: 1px solid #d4a373; padding-left: 20px;">{{Title}}</h3>
            </div>
            
            <div style="column-count: 2; column-gap: 30px; font-size: 14px; line-height: 1.8; color: #4b5a41;">
                {{Description}}
            </div>
        </div>
        <div class="botanical-footer">
            <div>DAY {{Day}} OF THE EXPEDITION</div>
            <div>{{../trip.destination}}</div>
        </div>
    </div>
    {{/each}}

    <!-- ================= ACCOMMODATION ================= -->
    <div class="pdf-page">
         <div style="padding: 40mm 20mm 20mm;">
            <h2 class="title-display" style="font-size: 48px; margin-bottom: 50px;">Stays & Sanctuaries</h2>

            <div style="display: grid; grid-template-columns: 1fr; gap: 30px;">
                {{#each hotels}}
                <div style="display: flex; gap: 30px; background: white; padding: 30px; border-radius: 50px 0 50px 0; border: 1px solid #f1f3f0;">
                    <div style="flex: 1;">
                        <div class="sub-hand" style="font-size: 20px; margin-bottom: 5px;">{{City}}</div>
                        <h3 class="title-display" style="font-size: 24px;">{{Name}}</h3>
                        <div class="label-modern" style="margin-top: 15px; display: flex; gap: 10px;">
                            <span>{{RoomType}}</span>
                            <span style="color: #d4a373;">✦</span>
                            <span>{{Category}} Star</span>
                        </div>
                    </div>
                    <div style="width: 120px; text-align: right; border-left: 1px solid #f1f3f0; padding-left: 20px;">
                        <div class="label-modern" style="font-size: 9px;">Stay Period</div>
                        <div style="font-size: 12px; font-weight: 700; margin-top: 5px;">{{CheckInDate}}</div>
                        <div style="font-size: 10px; color: #d4a373; margin: 5px 0;">Till Checkout</div>
                        <div style="font-size: 12px; font-weight: 700;">{{CheckOutDate}}</div>
                    </div>
                </div>
                {{/each}}
            </div>
         </div>
    </div>

    <!-- ================= PAYMENT ================= -->
    <div class="pdf-page">
        <div style="padding: 40mm 20mm 20mm;">
            <h2 class="title-display" style="font-size: 48px; margin-bottom: 50px;">Secure Booking</h2>

            <div style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 40px;">
                <div style="background: #2b3a30; color: #fefae0; padding: 40px; border-radius: 50px 0 50px 0;">
                    <h3 class="title-display" style="font-size: 28px; color: #d4a373; margin-bottom: 30px;">Bank Transfer</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        <div>
                            <div class="label-modern" style="color: #ccd5ae; letter-spacing: 1px;">Beneficiary Name</div>
                            <div style="font-size: 16px; font-weight: 700;">{{user.CompanyName}}</div>
                        </div>
                        <div>
                            <div class="label-modern" style="color: #ccd5ae; letter-spacing: 1px;">Bank & Branch</div>
                            <div style="font-size: 16px; font-weight: 700;">{{user.BankName}} · {{user.BranchName}}</div>
                        </div>
                        <div style="display: flex; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 20px;">
                            <div>
                                <div class="label-modern" style="color: #ccd5ae; letter-spacing: 1px;">Account Number</div>
                                <div style="font-size: 18px; font-weight: 700; color: #d4a373;">{{user.AccountNumber}}</div>
                            </div>
                            <div>
                                <div class="label-modern" style="color: #ccd5ae; letter-spacing: 1px;">IFSC Code</div>
                                <div style="font-size: 18px; font-weight: 700; color: #d4a373;">{{user.IfscCode}}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="text-align: center; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                    <div style="width: 200px; height: 200px; background: white; padding: 20px; border-radius: 30px; border: 2px dashed #ccd5ae;">
                        {{#if user.qrCode}}
                        <img src="{{user.qrCode}}" style="width: 100%; height: 100%; object-fit: contain;">
                        {{else}}
                        <div style="font-size: 10px; color: #a3ad98;">QR CODE<br>PENDING</div>
                        {{/if}}
                    </div>
                    <div class="sub-hand" style="margin-top: 20px; font-size: 22px;">Scan to Confirm</div>
                    <div class="label-modern" style="margin-top: 10px;">UPI: {{#if company.upi}}{{company.upi}}{{else}}pay@journeyrouters{{/if}}</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ================= POLICIES ================= -->
    <div class="pdf-page">
        <div style="padding: 40mm 20mm 20mm;">
             <h2 class="title-display" style="font-size: 48px; margin-bottom: 30px;">Final Notes</h2>
             <div style="font-size: 13px; line-height: 1.8; color: #4a5568; white-space: pre-line; background: white; padding: 40px; border-radius: 40px; border: 1px solid #f1f3f0; height: 620px; overflow: hidden;">
                {{cancellation}}
            </div>
        </div>
        <div class="botanical-footer" style="justify-content: center;">
             <div style="padding: 10px 40px; background: #2b3a30; color: white; border-radius: 50px;">THANK YOU FOR TRAVELING WITH US</div>
        </div>
    </div>

</body>

</html>
