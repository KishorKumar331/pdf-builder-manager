<!doctype html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <title>Journey Routers - Trip PDF</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Comic+Relief:wght@400;700&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Sour+Gummy:ital,wght@0,100..900;1,100..900&display=swap"
        rel="stylesheet">
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        body {
            margin: 0;
            font-family: "Sour Gummy", sans-serif;
            font-optical-sizing: auto;
        }

        .pdf-page {
            width: 210mm;
            height: 297mm;
            position: relative;
            overflow: hidden;
            page-break-after: always;
            background: #000;
            color: #fff;
        }

        .package-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 28px;
            margin-bottom: 50px;
        }

        .package-table th {
            background: #f5f5f5;
            padding: 20px 25px;
            border: 1px solid #ddd;
            font-weight: 600;
            text-align: left;
            width: 35%;
        }

        .package-table td {
            padding: 20px 25px;
            border: 1px solid #ddd;
            background: #fff;
        }

        .itinerary-item {
            display: flex;
            align-items: flex-start;
            gap: 20mm;
            break-inside: avoid;
            left: 10mm;
        }

        .itinerary-group {
            display: flex;
            padding: 2rem;
            flex-direction: column;
            gap: 20mm;
        }

        .pdf-footer {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 18px;
            font-size: 14px;
            color: white;
        }

        .footer {
            position: absolute;
            bottom: 18mm;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
        }

        .divider {
            width: 2px;
            height: 40px;
            background: #fff;
        }

        .page-header {
            width: 210mm;
            height: 65mm;
            padding-bottom: 20mm;
            background-repeat: no-repeat;
            background-position: top center;
            background-size: 100% auto;
        }
        
    /* Payment */
    .payment-layout {
      display: flex;
      gap: 2rem;
      margin: 2rem;
    }

    .payment-left {
      flex: 1;
    }

    .payment-table {
      width: 100%;
      color: black;
      border-collapse: collapse;
      font-size: 16px;
    }

    .payment-table th {
      background: #f5f5f5;
      padding: 12px 16px;
      border: 1px solid #ddd;
      text-align: left;
      width: 40%;
    }

    .payment-table td {
      padding: 12px 16px;
      border: 1px solid #ddd;
      background: #fff;
    }

    .qr-box {
      width: 220px;
      height: 220px;
      border-radius: 16px;
      border: 2px dashed #4a90e2;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #fff;
      margin-bottom: 1rem;
      margin-top: 1rem;
    }

    .qr-box span {
      text-align: center;
      font-size: 0.95rem;
      color: #555;
    }

    .paynow-btn {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.8rem 2.5rem;
      background: #4a90e2;
      color: #fff;
      border-radius: 999px;
      font-size: 1.1rem;
      font-weight: 600;
      text-decoration: none;
      text-align: center;
    }

    .paynow-btn:hover {
      background: #2f6bb0;
    }

    .payment-note {
      margin-top: 1.5rem;
      font-size: 0.95rem;
      color: #444;
    }
    </style>
</head>

<body>
    <!-- ================= PAGE 1 : COVER ================= -->


    <div style="    
      width: 210mm;
      height: 297mm;
      background-image:url('{{assetsBaseUrl}}/header.png');
        {{!-- background-image:url('{{assetsBaseUrl}}/destination/{{uppercase trip.destination}}/Header.png'); --}}
