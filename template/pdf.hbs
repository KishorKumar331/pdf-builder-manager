                {{company.email}}
            </div>

            <div style="font-size: 1.2rem; color: #000; margin-top: 0.5rem">
                {{company.address}}
            </div>
        </div>
    </div>

    <!-- ================= PAGE 2 : PACKAGE DETAILS ================= -->
