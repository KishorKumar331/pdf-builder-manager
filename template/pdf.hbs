<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Bespoke Journey PDF</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet" />
  <style>
    @page { size: A4; margin: 0; }
    body {
      margin: 0;
      font-family: 'Montserrat', sans-serif;
      background: #fff;
      color: #333;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .pdf-page, .pdf-page-dynamic {
      width: 210mm;
      position: relative;
      background: #fff;
      page-break-after: always;
      overflow: hidden;
      box-sizing: border-box;
    }
    
    .pdf-page {
      height: 297mm;
    }

    .pdf-page-dynamic {
      min-height: 297mm;
      height: auto;
      display: flex;
      flex-direction: column;
    }

    /* Colors */
    .bg-navy { background-color: #141f36; }
    .text-navy { color: #141f36; }
    .bg-gold { background-color: #c5a059; }
    .text-gold { color: #c5a059; }
    .bg-white { background-color: #ffffff; }
    .text-white { color: #ffffff; }
    .bg-light { background-color: #f9f9fa; }

    /* Typography */
    .font-serif { font-family: 'Playfair Display', serif; }
    .italic { font-style: italic; }
    .uppercase { text-transform: uppercase; }
    .tracking-wide { letter-spacing: 0.05em; }
    .tracking-wider { letter-spacing: 0.1em; }
    .tracking-widest { letter-spacing: 0.2em; }
    
    .section-title {
      font-size: 32px;
      margin: 40px 40px 20px 40px;
      color: #141f36;
    }

    /* Cover Page */
    .cover-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px;
    }
    .cover-logo-text {
      font-size: 10px;
      letter-spacing: 4px;
      margin-bottom: 40px;
      color: #c5a059;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .cover-logo-text img {
      height: 60px;
      margin-bottom: 15px;
    }
    .cover-title {
      font-size: 90px;
      color: #ffffff;
      line-height: 1;
      margin: 30px 0;
    }
    .cover-subtitle {
      font-size: 12px;
      color: #a0aabf;
      letter-spacing: 3px;
      margin-bottom: 10px;
    }
    .cover-divider {
      width: 1px;
      height: 80px;
      background: #c5a059;
      margin: 40px auto;
      position: relative;
    }
    .cover-divider::after {
      content: '';
      position: absolute;
      width: 6px;
      height: 6px;
      background: #c5a059;
      transform: rotate(45deg);
      left: -2.5px;
      top: 50%;
    }
    .cover-boxes {
      display: flex;
      gap: 20px;
      margin-top: 50px;
      width: 100%;
      max-width: 600px;
    }
    .cover-box {
      flex: 1;
      border: 1px solid rgba(255,255,255,0.1);
      padding: 20px 10px;
      background: rgba(255,255,255,0.02);
    }
    .cover-box-label {
      font-size: 8px;
      color: #c5a059;
      letter-spacing: 2px;
      margin-bottom: 10px;
    }
    .cover-box-value {
      font-size: 13px;
      color: #ffffff;
      font-weight: 500;
    }

    /* Page Header for inner pages */
    .inner-header {
      padding:4px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #eaeaea;
    }
    .inner-logo {
      height: 90px;
    }

    /* Stats Row */
    .stats-row {
      display: flex;
      margin: 0 40px 40px;
      border-top: 1px solid #eaeaea;
      border-bottom: 1px solid #eaeaea;
      padding: 30px 0;
    }
    .stat-item {
      flex: 1;
      text-align: center;
      border-right: 1px solid #eaeaea;
    }
    .stat-item:last-child {
      border-right: none;
    }
    .stat-value {
      font-size: 24px;
      font-weight: 700;
      color: #141f36;
      margin-bottom: 5px;
    }
    .stat-label {
      font-size: 9px;
      color: #c5a059;
      letter-spacing: 1px;
    }
    .stat-icon {
      font-size: 24px;
      color: #c5a059;
      margin-bottom: 10px;
    }

    /* Itinerary Day */
    .day-container {
      display: flex;
      flex: 1;
      border: 1px solid #eaeaea;
      background: #fff;
      page-break-inside: avoid;
    }
    .day-left {
      width: 80px;
      background: #141f36;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 25px;
      color: #fff;
    }
    .day-left-label {
      font-size: 10px;
      color: #c5a059;
      letter-spacing: 2px;
    }
    .day-left-num {
      font-size: 32px;
      font-weight: 600;
      margin-top: 5px;
    }
    .day-right {
      flex: 1;
    }
    .day-header {
      background: #141f36;
      color: #fff;
      padding: 18px 25px;
      border-left: 1px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
    }
    .day-header-title {
      font-size: 16px;
      font-weight: 600;
      flex: 1;
    }
    .day-body {
      padding: 30px;
    }
    .day-desc {
      font-size: 14px;
      line-height: 1.7;
      color: #444;
      margin-bottom: 20px;
    }
    .day-image {
      width: 100%;
      height: 220px;
      object-fit: cover;
      margin-bottom: 25px;
      border-radius: 4px;
    }

    /* Hotels */
    .hotel-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      margin: 0 40px 40px;
    }
    .hotel-card {
      border: 1px solid #eaeaea;
      padding: 30px;
      background: #fff;
    }
    .hotel-card-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
      border-bottom: 1px solid #eaeaea;
      padding-bottom: 20px;
    }
    .hotel-night {
      font-size: 11px;
      color: #c5a059;
      letter-spacing: 1px;
      margin-bottom: 5px;
    }
    .hotel-city {
      font-size: 16px;
      font-weight: 600;
      color: #141f36;
    }
    .hotel-name {
      font-size: 22px;
      color: #141f36;
      margin-bottom: 15px;
    }
    .hotel-detail-row {
      font-size: 13px;
      color: #555;
      margin-bottom: 8px;
    }

    /* Inclusions / Exclusions */
    .inc-exc-wrapper {
      display: flex;
      margin: 0 40px 40px;
      border: 1px solid #141f36;
    }
    .inc-col {
      flex: 1;
      padding: 40px;
      background: #fff;
    }
    .exc-col {
      flex: 1;
      padding: 40px;
      background: #141f36;
      color: #fff;
    }
    .inc-exc-title {
      font-size: 14px;
      letter-spacing: 2px;
      margin-bottom: 25px;
    }
    .inc-col .inc-exc-title { color: #c5a059; }
    .exc-col .inc-exc-title { color: #c5a059; }
    
    .list-item {
      display: flex;
      align-items: flex-start;
      margin-bottom: 15px;
      font-size: 13px;
      line-height: 1.6;
    }
    .inc-col .list-item { color: #333; }
    .exc-col .list-item { color: rgba(255,255,255,0.85); }
    .list-icon {
      margin-right: 12px;
      margin-top: 2px;
      flex-shrink: 0;
    }

    /* Generic Box */
    .content-box {
      margin: 0 40px 40px;
      padding: 35px;
      background: #f9f9fa;
      border: 1px solid #eaeaea;
      font-size: 14px;
      line-height: 1.8;
      color: #444;
      white-space: pre-line;
    }

    /* Footer */
    .pdf-footer {
      background: #141f36;
      color: rgba(255,255,255,0.6);
      padding: 20px 40px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      letter-spacing: 1px;
    }
    .pdf-footer-dynamic {
      margin-top: auto;
    }

    /* Itinerary Overview timeline */
    .overview-timeline {
      position: relative;
      margin: 10px 0 20px 0;
      padding-left: 30px;
    }
    .overview-timeline::before {
      content: '';
      position: absolute;
      left: 9px;
      top: 8px;
      bottom: 8px;
      width: 2px;
      background: #eaeaea;
    }
    .overview-timeline-item {
      position: relative;
      margin-bottom: 25px;
      page-break-inside: avoid;
    }
    .overview-timeline-item::before {
      content: '';
      position: absolute;
      left: -30px;
      top: 4px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #fff;
      border: 4px solid #c5a059;
      box-sizing: border-box;
      z-index: 10;
    }
    .overview-day-badge {
      font-size: 11px;
      font-weight: 700;
      color: #141f36;
      background: #f4f6f9;
      padding: 2px 6px;
      border-radius: 4px;
      display: inline-block;
    }
    .overview-date {
      font-size: 11px;
      color: #888;
      margin-left: 10px;
    }
    .overview-title {
      font-family: 'Playfair Display', serif;
      color: #141f36;
      margin: 5px 0;
      font-size: 15px;
      font-weight: 600;
      line-height: 1.4;
    }
    .overview-activities {
      font-size: 12px;
      color: #666;
      margin-top: 3px;
    }
    .overview-activities strong {
      color: #c5a059;
    }
  </style>
</head>
<body>

  <!-- PAGE 1: COVER -->
   <div style="padding: 0;" class="pdf-page bg-navy cover-page">
   
      {{#if user.organization.details.logourl}}
        <img src="https://d2w6ooepk5o1m0.cloudfront.net/winterfell_holidays/profile/WH_Header.png" alt="Logo"  style="    width: 100%;
    height: 100%;
    object-fit: contain;
}"/>
      {{/if}}
    


  </div>
  <div class="pdf-page bg-navy cover-page">
    <div class="cover-logo-text uppercase">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" alt="Logo" />
      {{/if}}
      {{company.name}} — A BESPOKE JOURNEY
    </div>

    <div class="font-serif italic cover-title">{{trip.destination}}</div>
    
    <div class="cover-subtitle uppercase">{{trip.days}} DAYS · {{trip.nights}} NIGHTS · {{uppercase trip.destination}}</div>
    <div class="cover-subtitle uppercase" style="color: #6a7489; font-size: 10px; margin-top: 15px;">
      {{formatDate trip.travelDate}} &nbsp;·&nbsp; {{trip.pax}} ADULTS &nbsp;·&nbsp; {{pricing.priceType}}
    </div>

    <div class="cover-divider"></div>

    <div class="cover-boxes">
      <div class="cover-box">
        <div class="cover-box-label uppercase">Curated For</div>
        <div class="cover-box-value">{{customer.name}}</div>
      </div>
      <div class="cover-box">
        <div class="cover-box-label uppercase">Travel Dates</div>
        <div class="cover-box-value">{{formatDate trip.travelDate}}</div>
      </div>
      <div class="cover-box">
        <div class="cover-box-label uppercase">Duration</div>
        <div class="cover-box-value">{{trip.nights}} Nights · {{trip.days}} Days</div>
      </div>
    </div>
  </div>

  <!-- PAGE 2: AT A GLANCE & ITINERARY -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      {{trip.days}} Days Across <span class="text-gold italic">{{trip.destination}}</span>
    </div>

    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-icon">🌴</div>
        <div class="stat-value">{{trip.days}}</div>
        <div class="stat-label uppercase">Days in {{trip.destination}}</div>
      </div>
      <div class="stat-item">
        <div class="stat-icon">👥</div>
        <div class="stat-value">{{trip.pax}}</div>
        <div class="stat-label uppercase">Adults</div>
      </div>
      <div class="stat-item">
        <div class="stat-icon">💰</div>
        <div class="stat-value" style="font-size:20px; margin-top:4px;">{{pricing.currency}} {{pricing.totalCost}}</div>
        <div class="stat-label uppercase">Total Investment</div>
      </div>
    </div>

    <!-- DAYWISE ITINERARY OVERVIEW -->
    <div style="margin: 0 40px 40px 40px;">
      <div style="font-size: 11px; letter-spacing: 2px; color: #c5a059; margin-bottom: 25px; border-bottom: 1px solid #eaeaea; padding-bottom: 10px;" class="uppercase font-serif">Itinerary Overview</div>
      <div class="overview-timeline">
        {{#each itinerary}}
        <div class="overview-timeline-item">
          <div style="display: flex; align-items: center; margin-bottom: 5px;">
            <span class="overview-day-badge">DAY {{#if Day}}{{Day}}{{else}}{{#if day}}{{day}}{{else}}{{inc @index}}{{/if}}{{/if}}</span>
            {{#if Date}}
              <span class="overview-date">{{formatDate Date}}</span>
            {{/if}}
          </div>
          <div class="overview-title">{{Title}}</div>
        
        </div>
        {{/each}}
      </div>
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGES: ITINERARY (One Day Per Page) -->
  {{#each itinerary}}
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if @root.user.organization.details.logourl}}
        <img src="{{@root.user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{@root.company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{@root.trip.tripId}}</div>
    </div>

    <div class="day-container" style="margin-top: {{#if @first}}0px{{else}}0px{{/if}};">
      <div class="day-left">
        <div class="day-left-label">DAY</div>
        <div class="day-left-num">{{#if Day}}0{{Day}}{{else}}0{{inc @index}}{{/if}}</div>
      </div>
      <div class="day-right">
        <div class="day-header font-serif uppercase">
          <span class="text-gold" style="font-family:'Montserrat', sans-serif; font-size:12px; margin-right:20px; letter-spacing:1px; font-weight:600;">DAY {{#if Day}}0{{Day}}{{else}}0{{inc @index}}{{/if}}</span> 
          <span class="day-header-title">{{Title}}</span>
        </div>
        <div class="day-body">
          {{#if ImageUrl}}
            <img src="{{ImageUrl}}" class="day-image" />
          {{/if}}
          <div class="day-desc splitsection">
            {{#splitLines Description}}
              <p style="margin: 0 0 12px 0;">{{this}}</p>
            {{/splitLines}}
          </div>
        </div>
      </div>
    </div>
    
    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{@root.company.name}}</span>
      <span>{{@root.user.organization.details.website}} &nbsp;|&nbsp; {{@root.user.Phone}}</span>
    </div>
  </div>
  {{/each}}

  <!-- PAGE 3: ACCOMMODATION & DETAILS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div style="font-size:11px; letter-spacing:3px; margin: 50px 40px 10px 40px; color:#c5a059;" class="uppercase">Suggested Stay Plan</div>
    <div class="section-title font-serif" style="margin-top: 0;">
      Accommodation <span class="text-gold italic">Overview</span>
    </div>

    <div class="hotel-grid">
      {{#each hotels}}
      <div class="hotel-card">
        <div class="hotel-card-header">
          <div>
            <div class="hotel-night uppercase">CHECK-IN: {{formatDate CheckInDate}}</div>
            <div class="hotel-city font-serif">{{City}}</div>
          </div>
        </div>
        <div class="hotel-name font-serif text-navy">{{Name}}</div>
        <div class="hotel-detail-row"><strong>Room:</strong> {{RoomType}}</div>
        <div class="hotel-detail-row"><strong>Meals:</strong> {{#each Meals}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
        <div class="hotel-detail-row" style="margin-top:15px; padding-top:15px; border-top:1px solid #eaeaea;">
          <strong>Check-Out:</strong> {{formatDate CheckOutDate}}
        </div>
      </div>
      {{/each}}
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE: INCLUSIONS & EXCLUSIONS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div style="font-size:11px; letter-spacing:3px; margin: 50px 40px 10px 40px; color:#c5a059;" class="uppercase">Package Details</div>
    <div class="section-title font-serif" style="margin-top: 0;">
      Inclusions <span class="text-gold italic">& Exclusions</span>
    </div>

    <div class="inc-exc-wrapper">
      <div class="inc-col">
        <div class="inc-exc-title uppercase font-serif">Package Inclusions</div>
        {{#each inclusions}}
        <div class="list-item">
          <div class="list-icon" style="color: #c5a059;">✓</div>
          <div>{{this}}</div>
        </div>
        {{/each}}
      </div>
      <div class="exc-col">
        <div class="inc-exc-title uppercase font-serif">Exclusions</div>
        {{#each exclusions}}
        <div class="list-item">
          <div class="list-icon" style="color: #c5a059;">✕</div>
          <div>{{this}}</div>
        </div>
        {{/each}}
      </div>
    </div>
    
    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE 4: CANCELLATION POLICY -->
  {{#if user.organization.cancellation}}
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      Cancellation <span class="text-gold italic">Policy</span>
    </div>

    <div class="content-box">
      {{{user.organization.cancellation}}}
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>
  {{/if}}

  <!-- PAGE 5: PAYMENT DETAILS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      Payment <span class="text-gold italic">Details</span>
    </div>

    <div class="hotel-grid"> 
      <div class="hotel-card">
        <div class="font-serif text-gold" style="margin-bottom:25px; font-size:24px;">Bank Account</div>
        
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Account Name</strong> <span style="color:#555;">{{user.BankName}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Bank Name</strong> <span style="color:#555;">{{user.BranchName}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Account No.</strong> <span style="color:#555;">{{user.AccountNumber}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>IFSC Code</strong> <span style="color:#555;">{{user.IfscCode}}</span>
        </div>
        <div style="margin-top:25px; font-size:12px; color:#888; font-style:italic; line-height:1.6;">
          * Please share payment proof with your travel consultant after completion.
        </div>
      </div>

      <div class="hotel-card" style="text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center;">
        <div class="font-serif text-gold" style="margin-bottom:25px; font-size:24px;">UPI / QR Payment</div>
        
        <div style="padding:20px; border:1px solid #eaeaea; background:#f9f9fa; border-radius:12px; margin-bottom:20px;">
          {{#if user.organization.financials.qrurl}}
            <img src="{{user.organization.financials.qrurl}}" alt="QR Code" style="width:200px; height:200px; border-radius:8px;" />
          {{else}}
            <div style="width:200px; height:200px; display:flex; align-items:center; justify-content:center; color:#ccc; border:2px dashed #ccc; border-radius:8px;">
              QR NOT AVAILABLE
            </div>
          {{/if}}
        </div>
        
        {{#if company.upi}}
        <div style="font-size:16px; font-weight:600; color:#141f36; padding:10px 20px; background:#f9f9fa; border-radius:30px; border:1px solid #eaeaea;">
          UPI ID: <span style="color:#555; font-weight:400; margin-left:10px;">{{company.upi}}</span>
        </div>
        {{/if}}
      </div>
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE 6: BACK COVER -->
  <div class="pdf-page bg-navy cover-page" style="justify-content:center;">
    <div class="font-serif uppercase tracking-widest text-gold" style="font-size:32px; margin-bottom: 25px;">
      {{company.name}}
    </div>
    <div class="uppercase tracking-widest text-white" style="font-size:11px; letter-spacing: 5px;">
      Bespoke Luxury Travel
    </div>
    <div class="cover-divider" style="margin: 50px auto;"></div>
    <div style="font-size:13px; color:rgba(255,255,255,0.6); line-height: 2.5; letter-spacing: 1px;">
      {{user.organization.details.website}} <br>
      {{user.Phone}}
    </div>
  </div>

  <div id="debug-log" style="background: #141f36; color: #fff; font-family: monospace; padding: 20px; font-size: 13px; line-height: 1.5; border-top: 5px solid #c5a059; border-bottom: 5px solid #c5a059; margin-top: 40px; overflow: visible;">
    <h3 style="color: #c5a059; margin-top: 0; font-family: 'Montserrat', sans-serif;">🔧 Pagination Debug Console</h3>
  </div>
  <style>
    @media print {
      #debug-log {
        display: none !important;
      }
    }
  </style>
  <script>
    function logDebug(msg) {
      console.log(msg);
      const logDiv = document.getElementById('debug-log');
      if (logDiv) {
        const p = document.createElement('div');
        p.style.margin = '0 0 5px 0';
        p.style.borderBottom = '1px solid rgba(255,255,255,0.05)';
        p.style.paddingBottom = '3px';
        p.innerText = msg;
        logDiv.appendChild(p);
      }
    }

    function initPagination() {
      logDebug("🚀 PDF Pagination: Initializing image load checks...");
      // Wait for all images to complete loading, with a maximum fallback timeout of 1000ms
      const images = Array.from(document.images);
      const promises = images.map(img => {
        if (img.complete) return Promise.resolve();
        return new Promise(resolve => {
          const timeoutId = setTimeout(() => {
            logDebug(`⌛ Image load timed out (using current layout size): ${img.src}`);
            resolve();
          }, 1000);
          img.onload = () => {
            clearTimeout(timeoutId);
            logDebug(`🖼️ Image loaded: ${img.src.split('/').pop()}`);
            resolve();
          };
          img.onerror = () => {
            clearTimeout(timeoutId);
            logDebug(`⚠️ Image failed to load: ${img.src.split('/').pop()}`);
            resolve();
          };
        });
      });

      Promise.all(promises).then(() => {
        logDebug("🏁 All images resolved/timed out. Starting pagination execution...");
        paginatePDF();
      });
    }

    if (document.readyState === 'complete' || document.readyState === 'interactive') {
      initPagination();
    } else {
      window.addEventListener('load', initPagination);
    }

    function paginatePDF() {
      // Create a temporary element to measure 297mm in pixels accurately
      const temp = document.createElement('div');
      temp.style.height = '297mm';
      temp.style.position = 'absolute';
      temp.style.visibility = 'hidden';
      document.body.appendChild(temp);
      const a4HeightPx = temp.offsetHeight;
      document.body.removeChild(temp);
      logDebug(`📏 Measured A4 height in browser pixels: ${a4HeightPx}px`);

      // Use a dynamic array list to process newly added pages recursively
      let pages = Array.from(document.querySelectorAll('.pdf-page-dynamic'));
      let i = 0;

      while (i < pages.length) {
        const page = pages[i];
        const splitSection = page.querySelector('.splitsection');
        if (!splitSection) {
          i++;
          continue;
        }

        const footer = page.querySelector('.pdf-footer');
        const footerHeight = footer ? footer.offsetHeight : 60;
        const maxContentHeight = a4HeightPx - footerHeight - 20; // 20px safety margin above footer

        // Check page bounding rect and splitSection bounding rect relative to page top
        const pageRect = page.getBoundingClientRect();
        const splitRect = splitSection.getBoundingClientRect();
        const splitRelativeBottom = splitRect.bottom - pageRect.top;
        logDebug(`📄 Page ${i + 1} - splitRelativeBottom: ${Math.round(splitRelativeBottom)}px (Limit: ${maxContentHeight}px)`);

        if (splitRelativeBottom <= maxContentHeight) {
          i++;
          continue;
        }

        // We have overflow! Let's paginate its children.
        const children = Array.from(splitSection.children);
        if (children.length === 0) {
          i++;
          continue;
        }

        logDebug(`⚡ Page ${i + 1} overflows! Splitting ${children.length} paragraphs...`);

        // Clear the split section contents
        splitSection.innerHTML = '';

        let currentPage = page;
        let currentSplitSection = splitSection;

        for (let child of children) {
          currentSplitSection.appendChild(child);

          // Measure child bottom position relative to the current page top
          const childRect = child.getBoundingClientRect();
          const currentPageRect = currentPage.getBoundingClientRect();
          const childRelativeBottom = childRect.bottom - currentPageRect.top;

          // If the child overflows the current page bottom (and it's not the only child on this page)
          if (currentSplitSection.children.length > 1 && childRelativeBottom > maxContentHeight) {
            logDebug(`✂️ Paragraph overflows at ${Math.round(childRelativeBottom)}px (Limit: ${maxContentHeight}px). Creating new page.`);
            
            // Remove the child from the current page
            currentSplitSection.removeChild(child);

            // Clone the current page to preserve header/footer and layouts
            const newPage = currentPage.cloneNode(true);
            
            // Empty the split section of the cloned page
            const newSplitSection = newPage.querySelector('.splitsection');
            if (newSplitSection) {
              newSplitSection.innerHTML = '';
            }

            // Remove day-image on subsequent pages to prevent image repetition and save space
            const newImage = newPage.querySelector('.day-image');
            if (newImage) {
              newImage.remove();
            }

            // Insert the new page in the DOM after the current page
            currentPage.parentNode.insertBefore(newPage, currentPage.nextSibling);

            // Insert the new page into our pages array so it gets checked on subsequent iterations
            pages.splice(i + 1, 0, newPage);

            // Update page references for subsequent children
            currentPage = newPage;
            currentSplitSection = newSplitSection;

            // Append the child to the new page's split section
            currentSplitSection.appendChild(child);
          }
        }

        i++;
      }

      logDebug("✅ Pagination completed. Enforcing fixed A4 heights on all pages.");
      // Lock height of all pages to exact A4 size for printing
      const allPages = document.querySelectorAll('.pdf-page-dynamic');
      allPages.forEach(p => {
        p.style.height = a4HeightPx + 'px';
        p.style.overflow = 'hidden';
        p.style.boxSizing = 'border-box';
      });
    }
  </script>
</body>
</html>