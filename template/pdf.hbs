<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Bespoke Journey PDF</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&display=swap" rel="stylesheet" />
  <style>
    @page { size: A4; margin: 0; }
    body {
      margin: 0;
      font-family: 'Montserrat', sans-serif;
      background: #fff;
      color: #333;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .pdf-page, .pdf-page-dynamic {
      width: 210mm;
      position: relative;
      background: #fff;
      page-break-after: always;
      overflow: hidden;
      box-sizing: border-box;
    }
    
    .pdf-page {
      height: 297mm;
    }

    .pdf-page-dynamic {
      min-height: 297mm;
      height: auto;
      display: flex;
      flex-direction: column;
    }

    /* Colors */
    .bg-navy { background-color: #141f36; }
    .text-navy { color: #141f36; }
    .bg-gold { background-color: #c5a059; }
    .text-gold { color: #c5a059; }
    .bg-white { background-color: #ffffff; }
    .text-white { color: #ffffff; }
    .bg-light { background-color: #f9f9fa; }

    /* Typography */
    .font-serif { font-family: 'Playfair Display', serif; }
    .italic { font-style: italic; }
    .uppercase { text-transform: uppercase; }
    .tracking-wide { letter-spacing: 0.05em; }
    .tracking-wider { letter-spacing: 0.1em; }
    .tracking-widest { letter-spacing: 0.2em; }
    
    .section-title {
      font-size: 32px;
      margin: 40px 40px 20px 40px;
      color: #141f36;
    }

    /* Cover Page */
    .cover-page {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px;
    }
    .cover-logo-text {
      font-size: 10px;
      letter-spacing: 4px;
      margin-bottom: 40px;
      color: #c5a059;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .cover-logo-text img {
      height: 60px;
      margin-bottom: 15px;
    }
    .cover-title {
      font-size: 90px;
      color: #ffffff;
      line-height: 1;
      margin: 30px 0;
    }
    .cover-subtitle {
      font-size: 12px;
      color: #a0aabf;
      letter-spacing: 3px;
      margin-bottom: 10px;
    }
    .cover-divider {
      width: 1px;
      height: 80px;
      background: #c5a059;
      margin: 40px auto;
      position: relative;
    }
    .cover-divider::after {
      content: '';
      position: absolute;
      width: 6px;
      height: 6px;
      background: #c5a059;
      transform: rotate(45deg);
      left: -2.5px;
      top: 50%;
    }
    .cover-boxes {
      display: flex;
      gap: 20px;
      margin-top: 50px;
      width: 100%;
      max-width: 600px;
    }
    .cover-box {
      flex: 1;
      border: 1px solid rgba(255,255,255,0.1);
      padding: 20px 10px;
      background: rgba(255,255,255,0.02);
    }
    .cover-box-label {
      font-size: 8px;
      color: #c5a059;
      letter-spacing: 2px;
      margin-bottom: 10px;
    }
    .cover-box-value {
      font-size: 13px;
      color: #ffffff;
      font-weight: 500;
    }

    /* Page Header for inner pages */
    .inner-header {
      padding: 30px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #eaeaea;
    }
    .inner-logo {
      height: 40px;
    }

    /* Stats Row */
    .stats-row {
      display: flex;
      margin: 0 40px 40px;
      border-top: 1px solid #eaeaea;
      border-bottom: 1px solid #eaeaea;
      padding: 30px 0;
    }
    .stat-item {
      flex: 1;
      text-align: center;
      border-right: 1px solid #eaeaea;
    }
    .stat-item:last-child {
      border-right: none;
    }
    .stat-value {
      font-size: 24px;
      font-weight: 700;
      color: #141f36;
      margin-bottom: 5px;
    }
    .stat-label {
      font-size: 9px;
      color: #c5a059;
      letter-spacing: 1px;
    }
    .stat-icon {
      font-size: 24px;
      color: #c5a059;
      margin-bottom: 10px;
    }

    /* Itinerary Day */
    .day-container {
      margin: 0 40px 30px 40px;
      display: flex;
      flex: 1;
      border: 1px solid #eaeaea;
      background: #fff;
      page-break-inside: avoid;
    }
    .day-left {
      width: 80px;
      background: #141f36;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 25px;
      color: #fff;
    }
    .day-left-label {
      font-size: 10px;
      color: #c5a059;
      letter-spacing: 2px;
    }
    .day-left-num {
      font-size: 32px;
      font-weight: 600;
      margin-top: 5px;
    }
    .day-right {
      flex: 1;
    }
    .day-header {
      background: #141f36;
      color: #fff;
      padding: 18px 25px;
      border-left: 1px solid rgba(255,255,255,0.1);
      display: flex;
      align-items: center;
    }
    .day-header-title {
      font-size: 16px;
      font-weight: 600;
      flex: 1;
    }
    .day-body {
      padding: 30px;
    }
    .day-desc {
      font-size: 14px;
      line-height: 1.7;
      color: #444;
      margin-bottom: 20px;
    }
    .day-image {
      width: 100%;
      height: 220px;
      object-fit: cover;
      margin-bottom: 25px;
      border-radius: 4px;
    }

    /* Hotels */
    .hotel-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 30px;
      margin: 0 40px 40px;
    }
    .hotel-card {
      border: 1px solid #eaeaea;
      padding: 30px;
      background: #fff;
    }
    .hotel-card-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
      border-bottom: 1px solid #eaeaea;
      padding-bottom: 20px;
    }
    .hotel-night {
      font-size: 11px;
      color: #c5a059;
      letter-spacing: 1px;
      margin-bottom: 5px;
    }
    .hotel-city {
      font-size: 16px;
      font-weight: 600;
      color: #141f36;
    }
    .hotel-name {
      font-size: 22px;
      color: #141f36;
      margin-bottom: 15px;
    }
    .hotel-detail-row {
      font-size: 13px;
      color: #555;
      margin-bottom: 8px;
    }

    /* Inclusions / Exclusions */
    .inc-exc-wrapper {
      display: flex;
      margin: 0 40px 40px;
      border: 1px solid #141f36;
    }
    .inc-col {
      flex: 1;
      padding: 40px;
      background: #fff;
    }
    .exc-col {
      flex: 1;
      padding: 40px;
      background: #141f36;
      color: #fff;
    }
    .inc-exc-title {
      font-size: 14px;
      letter-spacing: 2px;
      margin-bottom: 25px;
    }
    .inc-col .inc-exc-title { color: #c5a059; }
    .exc-col .inc-exc-title { color: #c5a059; }
    
    .list-item {
      display: flex;
      align-items: flex-start;
      margin-bottom: 15px;
      font-size: 13px;
      line-height: 1.6;
    }
    .inc-col .list-item { color: #333; }
    .exc-col .list-item { color: rgba(255,255,255,0.85); }
    .list-icon {
      margin-right: 12px;
      margin-top: 2px;
      flex-shrink: 0;
    }

    /* Generic Box */
    .content-box {
      margin: 0 40px 40px;
      padding: 35px;
      background: #f9f9fa;
      border: 1px solid #eaeaea;
      font-size: 14px;
      line-height: 1.8;
      color: #444;
      white-space: pre-line;
    }

    /* Footer */
    .pdf-footer {
      background: #141f36;
      color: rgba(255,255,255,0.6);
      padding: 20px 40px;
      display: flex;
      justify-content: space-between;
      font-size: 11px;
      letter-spacing: 1px;
    }
    .pdf-footer-dynamic {
      margin-top: auto;
    }
  </style>
</head>
<body>

  <!-- PAGE 1: COVER -->
  <div class="pdf-page bg-navy cover-page">
    <div class="cover-logo-text uppercase">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" alt="Logo" />
      {{/if}}
      {{company.name}} — A BESPOKE JOURNEY
    </div>

    <div class="font-serif italic cover-title">{{trip.destination}}</div>
    
    <div class="cover-subtitle uppercase">{{trip.days}} DAYS · {{trip.nights}} NIGHTS · {{uppercase trip.destination}}</div>
    <div class="cover-subtitle uppercase" style="color: #6a7489; font-size: 10px; margin-top: 15px;">
      {{formatDate trip.travelDate}} &nbsp;·&nbsp; {{trip.pax}} ADULTS &nbsp;·&nbsp; {{pricing.priceType}}
    </div>

    <div class="cover-divider"></div>

    <div class="cover-boxes">
      <div class="cover-box">
        <div class="cover-box-label uppercase">Curated For</div>
        <div class="cover-box-value">{{customer.name}}</div>
      </div>
      <div class="cover-box">
        <div class="cover-box-label uppercase">Travel Dates</div>
        <div class="cover-box-value">{{formatDate trip.travelDate}}</div>
      </div>
      <div class="cover-box">
        <div class="cover-box-label uppercase">Duration</div>
        <div class="cover-box-value">{{trip.nights}} Nights · {{trip.days}} Days</div>
      </div>
    </div>
  </div>

  <!-- PAGE 2: AT A GLANCE & ITINERARY -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      {{trip.days}} Days Across <span class="text-gold italic">{{trip.destination}}</span>
    </div>

    <div class="stats-row">
      <div class="stat-item">
        <div class="stat-icon">🌴</div>
        <div class="stat-value">{{trip.days}}</div>
        <div class="stat-label uppercase">Days in {{trip.destination}}</div>
      </div>
      <div class="stat-item">
        <div class="stat-icon">👥</div>
        <div class="stat-value">{{trip.pax}}</div>
        <div class="stat-label uppercase">Adults</div>
      </div>
      <div class="stat-item">
        <div class="stat-icon">💰</div>
        <div class="stat-value" style="font-size:20px; margin-top:4px;">{{pricing.currency}} {{pricing.totalCost}}</div>
        <div class="stat-label uppercase">Total Investment</div>
      </div>
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGES: ITINERARY (One Day Per Page) -->
  {{#each itinerary}}
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if @root.user.organization.details.logourl}}
        <img src="{{@root.user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{@root.company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{@root.trip.tripId}}</div>
    </div>

    {{#if @first}}
    <div class="section-title font-serif" style="margin-top: 40px;">
      Your <span class="text-gold italic">Journey</span>
    </div>
    {{/if}}

    <div class="day-container" style="margin-top: {{#if @first}}10px{{else}}40px{{/if}};">
      <div class="day-left">
        <div class="day-left-label">DAY</div>
        <div class="day-left-num">{{#if Day}}0{{Day}}{{else}}0{{inc @index}}{{/if}}</div>
      </div>
      <div class="day-right">
        <div class="day-header font-serif uppercase">
          <span class="text-gold" style="font-family:'Montserrat', sans-serif; font-size:12px; margin-right:20px; letter-spacing:1px; font-weight:600;">DAY {{#if Day}}0{{Day}}{{else}}0{{inc @index}}{{/if}}</span> 
          <span class="day-header-title">{{Title}}</span>
        </div>
        <div class="day-body">
          {{#if ImageUrl}}
            <img src="{{optimizeUnsplash ImageUrl 600 60}}" class="day-image" />
          {{/if}}
          <div class="day-desc">
            {{#splitLines Description}}
              <p style="margin: 0 0 12px 0;">{{this}}</p>
            {{/splitLines}}
          </div>
        </div>
      </div>
    </div>
    
    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{@root.company.name}}</span>
      <span>{{@root.user.organization.details.website}} &nbsp;|&nbsp; {{@root.user.Phone}}</span>
    </div>
  </div>
  {{/each}}

  <!-- PAGE 3: ACCOMMODATION & DETAILS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div style="font-size:11px; letter-spacing:3px; margin: 50px 40px 10px 40px; color:#c5a059;" class="uppercase">Suggested Stay Plan</div>
    <div class="section-title font-serif" style="margin-top: 0;">
      Accommodation <span class="text-gold italic">Overview</span>
    </div>

    <div class="hotel-grid">
      {{#each hotels}}
      <div class="hotel-card">
        <div class="hotel-card-header">
          <div>
            <div class="hotel-night uppercase">CHECK-IN: {{formatDate CheckInDate}}</div>
            <div class="hotel-city font-serif">{{City}}</div>
          </div>
        </div>
        <div class="hotel-name font-serif text-navy">{{Name}}</div>
        <div class="hotel-detail-row"><strong>Room:</strong> {{RoomType}}</div>
        <div class="hotel-detail-row"><strong>Meals:</strong> {{#each Meals}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
        <div class="hotel-detail-row" style="margin-top:15px; padding-top:15px; border-top:1px solid #eaeaea;">
          <strong>Check-Out:</strong> {{formatDate CheckOutDate}}
        </div>
      </div>
      {{/each}}
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE: INCLUSIONS & EXCLUSIONS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div style="font-size:11px; letter-spacing:3px; margin: 50px 40px 10px 40px; color:#c5a059;" class="uppercase">Package Details</div>
    <div class="section-title font-serif" style="margin-top: 0;">
      Inclusions <span class="text-gold italic">& Exclusions</span>
    </div>

    <div class="inc-exc-wrapper">
      <div class="inc-col">
        <div class="inc-exc-title uppercase font-serif">Package Inclusions</div>
        {{#each inclusions}}
        <div class="list-item">
          <div class="list-icon" style="color: #c5a059;">✓</div>
          <div>{{this}}</div>
        </div>
        {{/each}}
      </div>
      <div class="exc-col">
        <div class="inc-exc-title uppercase font-serif">Exclusions</div>
        {{#each exclusions}}
        <div class="list-item">
          <div class="list-icon" style="color: #c5a059;">✕</div>
          <div>{{this}}</div>
        </div>
        {{/each}}
      </div>
    </div>
    
    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE 4: CANCELLATION POLICY -->
  {{#if user.organization.cancellation}}
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      Cancellation <span class="text-gold italic">Policy</span>
    </div>

    <div class="content-box">
      {{{user.organization.cancellation}}}
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>
  {{/if}}

  <!-- PAGE 5: PAYMENT DETAILS -->
  <div class="pdf-page-dynamic">
    <div class="inner-header">
      {{#if user.organization.details.logourl}}
        <img src="{{user.organization.details.logourl}}" class="inner-logo" />
      {{else}}
        <div class="text-navy font-serif italic" style="font-size:24px;">{{company.name}}</div>
      {{/if}}
      <div style="font-size:11px; color:#c5a059; letter-spacing:1px;" class="uppercase">TRIP ID: {{trip.tripId}}</div>
    </div>

    <div class="section-title font-serif">
      Payment <span class="text-gold italic">Details</span>
    </div>

    <div class="hotel-grid"> 
      <div class="hotel-card">
        <div class="font-serif text-gold" style="margin-bottom:25px; font-size:24px;">Bank Account</div>
        
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Account Name</strong> <span style="color:#555;">{{user.BankName}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Bank Name</strong> <span style="color:#555;">{{user.BranchName}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>Account No.</strong> <span style="color:#555;">{{user.AccountNumber}}</span>
        </div>
        <div style="display:flex; justify-content:space-between; border-bottom:1px solid #eaeaea; padding:15px 0; font-size:14px;">
          <strong>IFSC Code</strong> <span style="color:#555;">{{user.IfscCode}}</span>
        </div>
        <div style="margin-top:25px; font-size:12px; color:#888; font-style:italic; line-height:1.6;">
          * Please share payment proof with your travel consultant after completion.
        </div>
      </div>

      <div class="hotel-card" style="text-align:center; display:flex; flex-direction:column; align-items:center; justify-content:center;">
        <div class="font-serif text-gold" style="margin-bottom:25px; font-size:24px;">UPI / QR Payment</div>
        
        <div style="padding:20px; border:1px solid #eaeaea; background:#f9f9fa; border-radius:12px; margin-bottom:20px;">
          {{#if user.organization.financials.qrurl}}
            <img src="{{user.organization.financials.qrurl}}" alt="QR Code" style="width:200px; height:200px; border-radius:8px;" />
          {{else}}
            <div style="width:200px; height:200px; display:flex; align-items:center; justify-content:center; color:#ccc; border:2px dashed #ccc; border-radius:8px;">
              QR NOT AVAILABLE
            </div>
          {{/if}}
        </div>
        
        {{#if company.upi}}
        <div style="font-size:16px; font-weight:600; color:#141f36; padding:10px 20px; background:#f9f9fa; border-radius:30px; border:1px solid #eaeaea;">
          UPI ID: <span style="color:#555; font-weight:400; margin-left:10px;">{{company.upi}}</span>
        </div>
        {{/if}}
      </div>
    </div>

    <div class="pdf-footer pdf-footer-dynamic">
      <span class="uppercase font-serif" style="font-size: 13px;">{{company.name}}</span>
      <span>{{user.organization.details.website}} &nbsp;|&nbsp; {{user.Phone}}</span>
    </div>
  </div>

  <!-- PAGE 6: BACK COVER -->
  <div class="pdf-page bg-navy cover-page" style="justify-content:center;">
    <div class="font-serif uppercase tracking-widest text-gold" style="font-size:32px; margin-bottom: 25px;">
      {{company.name}}
    </div>
    <div class="uppercase tracking-widest text-white" style="font-size:11px; letter-spacing: 5px;">
      Bespoke Luxury Travel
    </div>
    <div class="cover-divider" style="margin: 50px auto;"></div>
    <div style="font-size:13px; color:rgba(255,255,255,0.6); line-height: 2.5; letter-spacing: 1px;">
      {{user.organization.details.website}} <br>
      {{user.Phone}}
    </div>
  </div>

</body>
</html>