            </div>
        </div>
        <svg style="position: absolute;
             top: 159mm;
        left: 59mm;
          text-align: center;
          z-index: 1;
          color: #000;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          font-weight: 500;" width="420" height="260" viewBox="0 0 420 260" xmlns="http://www.w3.org/2000/svg">

                <!-- Background shadow -->
            <rect x="46" y="44" rx="22" ry="22" width="320" height="160" fill="#3F6FCB" opacity="0.95" />

            <!-- Main card -->
            <rect x="24" y="22" rx="22" ry="22" width="320" height="160" fill="#1F1F1F" />

            <!-- Soft highlight gradient -->
            <defs>
                <linearGradient id="shine" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.08" />
                    <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0" />
                </linearGradient>
            </defs>

            <rect x="24" y="22" rx="22" ry="22" width="320" height="160" fill="url(#shine)" />

            <!-- Floating accent shapes -->
            <circle cx="295" cy="45" r="8" fill="#4E7FE3" />
            <circle cx="310" cy="65" r="4" fill="#4E7FE3" />

            <rect x="55" y="150" width="36" height="8" rx="4" fill="#4E7FE3" transform="rotate(-12 55 150)" />

            <rect x="310" y="150" width="28" height="8" rx="4" fill="#4E7FE3" transform="rotate(18 310 150)" />

            <!-- Corner notch effect -->
            <path d="M24 44 Q24 22 46 22" fill="#4E7FE3" opacity="0.8" />

        </svg>


        <!-- Footer -->
        <div style="
          display: flex;
          position: absolute;
        bottom:0;
          align-items: center;
          justify-content: center;
          font-size: 14px;
          color: #ffffff;
